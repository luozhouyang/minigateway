{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "rootDirs": ["./src", "../core/src"],
    "composite": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@minigateway/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*", "../core/src/**/*"],
  "exclude": ["node_modules", "dist", "../core/src/**/*.test.ts", "../core/src/**/*.test.tsx"]
}
