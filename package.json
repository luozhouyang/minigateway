{
  "name": "minigateway",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "bootstrap": "node ./scripts/bootstrap-workspace.mjs",
    "check": "node ./scripts/run-local-vp.mjs check package.json scripts && node ./scripts/run-workspace-task.mjs check",
    "test": "node ./scripts/run-workspace-task.mjs test",
    "build": "node ./scripts/run-workspace-task.mjs build",
    "ready": "node ./scripts/run-local-vp.mjs run check && node ./scripts/run-local-vp.mjs run test && node ./scripts/run-local-vp.mjs run build",
    "dev": "node ./scripts/run-local-vp.mjs run website#dev",
    "e2e:smoke": "bash ./scripts/e2e-smoke.sh",
    "prepare": "node ./scripts/run-local-vp.mjs config",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:check": "node ./scripts/run-local-vp.mjs run check && node ./scripts/run-local-vp.mjs run test && node ./scripts/run-local-vp.mjs run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "vite-plus": "0.1.13"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
